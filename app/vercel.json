{
  "framework": "nextjs",
  "buildCommand": "next build",
  "devCommand": "next dev",
  "installCommand": "npm install",
  "outputDirectory": ".next",
  "crons": [
    {
      "path": "/api/cron/weekly-digest",
      "schedule": "0 14 * * 0"
    },
    {
      "path": "/api/cron/play-reminder",
      "schedule": "0 20 * * *"
    },
    {
      "path": "/api/cron/cleanup-guests",
      "schedule": "0 3 * * *"
    }
  ]
}
