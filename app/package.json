    "smoke:local": "node ./scripts/live-smoke.mjs",
    "smoke:backend": "node ./scripts/backend-smoke.mjs",
    "smoke:beta": "npm run smoke:local && npm run smoke:backend"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.99.3",
    "next": "16.1.0",
    "pg": "^8.20.0",
    "react": "19.2.0",
    "react-dom": "19.2.0"
  },
  "devDependencies": {
    "@types/node": "24.10.1",
    "@types/pg": "^8.20.0",
    "@types/react": "19.2.2",
    "@types/react-dom": "19.2.2",
    "typescript": "5.9.3"
  }
}
