{
  "name": "wonderquest-learning-app",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start --hostname 0.0.0.0 --port ${PORT:-3000}",
    "lint": "tsc --noEmit",
    "db:check": "node ./scripts/check-db-connectivity.mjs",
    "db:diagnose": "node ./scripts/diagnose-db-connectivity.mjs",
    "db:apply": "node ./scripts/apply-supabase-foundation.mjs",
    "db:sync-launch": "node ./scripts/sync-launch-content.mjs",
    "smoke:local": "node ./scripts/live-smoke.mjs",
    "smoke:backend": "node ./scripts/backend-smoke.mjs",
    "smoke:beta": "npm run smoke:local && npm run smoke:backend",
    "test:auth": "node --test src/__tests__/auth-gates.test.ts",
    "smoke:prod": "BASE_URL=https://wonderquest-learning.onrender.com bash ../tools/synthetic_monitor.sh"
  },
  "dependencies": {
    "@ducanh2912/next-pwa": "^10.2.9",
    "@supabase/supabase-js": "^2.99.3",
    "next": "16.1.0",
    "pg": "^8.20.0",
    "posthog-js": "^1.365.4",
    "posthog-node": "^5.29.1",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "resend": "^3.0.0",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@types/node": "24.10.1",
    "@types/pg": "^8.20.0",
    "@types/react": "19.2.2",
    "@types/react-dom": "19.2.2",
    "@types/web-push": "^3.6.4",
    "typescript": "5.9.3"
  }
}
