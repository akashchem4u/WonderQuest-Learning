{
  "name": "wonderquest-learning-app",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start --hostname 0.0.0.0 --port ${PORT:-3000}",
    "lint": "tsc --noEmit",
    "db:check": "node ./scripts/check-db-connectivity.mjs",
    "db:apply": "node ./scripts/apply-supabase-foundation.mjs",
